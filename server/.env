# Server Configuration
PORT=5001
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# -------------------------------------------
# MongoDB Configuration
# -------------------------------------------
# Get your connection string from MongoDB Atlas:
# https://cloud.mongodb.com/
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/empathetic-workspace?retryWrites=true&w=majority

# -------------------------------------------
# Google OAuth 2.0 Configuration
# -------------------------------------------
# Create credentials at: https://console.cloud.google.com/apis/credentials
# 1. Create a new OAuth 2.0 Client ID
# 2. Set authorized redirect URI to: http://localhost:5001/api/auth/google/callback
# 3. Enable Gmail API at: https://console.cloud.google.com/apis/library/gmail.googleapis.com
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

